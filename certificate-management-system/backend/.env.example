PORT=5005
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-name>.mongodb.net/certificate-management?retryWrites=true&w=majority
# Optional fallback key (same value format as MONGODB_URI)
MONGODB_ATLAS_URI=
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRE=7d
FRONTEND_URL=https://your-frontend-app.vercel.app
# Optional: comma-separated list if you need multiple domains.
# ALLOWED_ORIGINS=https://your-frontend-app.vercel.app,https://preview-branch.vercel.app

